# AutoAgent Environment Configuration
# Copy this file to .env and fill in values

# ── GitHub API ───────────────────────────────────
# Optional but strongly recommended (5000 req/hr vs 10 req/min unauthenticated)
# Create at: https://github.com/settings/tokens (scope: public_repo)
GITHUB_TOKEN=

# ── Ollama ───────────────────────────────────────
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Backend ──────────────────────────────────────
BACKEND_PORT=8000
LOG_LEVEL=INFO

# ── Sandbox ──────────────────────────────────────
# Max execution time in seconds (default: 180)
MAX_EXECUTION_SECONDS=180
# Sandbox base directory (default: /tmp/ai_agent)
SANDBOX_BASE=/tmp/ai_agent
